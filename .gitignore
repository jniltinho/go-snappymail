# Binaries
/dist/
/coverage.out
*.exe
*.dll
*.so
*.dylib

# Go
*.test
*.out
/vendor/

# Embedded SPA: only web/dist/ placeholder is tracked until frontend/ exists
/frontend/
/frontend/node_modules/

# Local runtime / secrets
/data/
/tmp/
/config.toml
/config_*.toml
**/.env
!**/.env.example
*.pem
*.key
*.crt
!docker/mailserver/templates/**

# SQLite / local DB files
*.db
*.sqlite
*.sqlite3

# Logs and caches
*.log
.cache/

# UPX download artifacts
/upx-*

# Reference tree (read-only SnappyMail PHP — ~100MB, not part of this repo)
/base/

# Agent / IDE tooling (local only — never commit)
/.agents/
/.claude/
/.claude
/.cursor/
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# Vagrant machine state and empty mount placeholders
/vagrant/.vagrant/
/vagrant/go-cubemail/
/vagrant/go-postfixadmin/
/vagrant/go-snappymail/

# Generated screenshots (keep README only)
/docs/prints/*.png
